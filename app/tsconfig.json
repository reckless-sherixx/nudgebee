{
  "compilerOptions": {
    "target": "es6",
    "lib": ["dom", "dom.iterable", "esnext"],
    "strictPropertyInitialization": false,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@config": ["./src/config"],
      "@components": ["./src/components"],
      "@components/*": ["./src/components/*"],
      "@ui": ["./src/components/common/ds"],
      "@ui/*": ["./src/components/common/ds/*"],
      "@shared": ["./src/components/common"],
      "@shared/*": ["./src/components/common/*"],
      "@data": ["./src/data"],
      "@data/*": ["./src/data/*"],
      "@assets": ["./src/assets/images"],
      "@assets/*": ["./src/assets/images/*"],
      "@pages": ["./src/pages"],
      "@pages/*": ["./src/pages/*"],
      "@context": ["./src/context"],
      "@context/*": ["./src/context/*"],
      "@api1": ["./src/api1"],
      "@api1/*": ["./src/api1/*"],
      "@hooks": ["./src/hooks"],
      "@hooks/*": ["./src/hooks/*"],
      "@lib": ["./src/lib"],
      "@lib/*": ["./src/lib/*"],
      "@utils": ["./src/utils"],
      "@utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src", "**/*.d.ts", "src/types/*.d.ts"],
  "exclude": ["node_modules", "src/components/in-progress"]
}
